---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import StatCard from '../components/StatCard.astro';
---

<DashboardLayout title="Analytics" subtitle="Performance-Metriken & Trends">
  <!-- KPIs -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <div class="animate-fade-in-up stagger-1">
      <StatCard label="Seitenaufrufe" value="124.5K" change="+18.3%" changeType="positive" />
    </div>
    <div class="animate-fade-in-up stagger-2">
      <StatCard label="Absprungrate" value="32.4%" change="-5.1%" changeType="positive" />
    </div>
    <div class="animate-fade-in-up stagger-3">
      <StatCard label="Sitzungsdauer" value="4m 32s" change="+0.8%" changeType="positive" />
    </div>
    <div class="animate-fade-in-up stagger-4">
      <StatCard label="Conversions" value="3.2%" change="-0.4%" changeType="negative" />
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <!-- Traffic Sources -->
    <div class="glass-frosted rounded-2xl p-6 animate-fade-in-up stagger-5">
      <h2 class="text-lg font-semibold text-[var(--color-text)] mb-6">Traffic-Quellen</h2>
      <div class="space-y-4">
        {[
          { source: 'Organische Suche', value: 45, color: 'bg-[var(--color-accent)]' },
          { source: 'Direkt', value: 28, color: 'bg-[var(--color-info)]' },
          { source: 'Social Media', value: 18, color: 'bg-[var(--color-success)]' },
          { source: 'E-Mail', value: 6, color: 'bg-[var(--color-warning)]' },
          { source: 'Referral', value: 3, color: 'bg-[var(--color-error)]' },
        ].map((item) => (
          <div>
            <div class="flex justify-between text-sm mb-1.5">
              <span class="font-medium text-[var(--color-text)]">{item.source}</span>
              <span class="text-[var(--color-text-secondary)]">{item.value}%</span>
            </div>
            <div class="h-2 bg-[var(--color-bg-secondary)] rounded-full overflow-hidden">
              <div class={`h-full rounded-full transition-all duration-1000 ${item.color}`} style={`width: ${item.value}%`}></div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Visitor Chart -->
    <div class="glass-frosted rounded-2xl p-6 animate-fade-in-up stagger-6">
      <h2 class="text-lg font-semibold text-[var(--color-text)] mb-6">Besucher-Trend</h2>
      <div class="h-64 relative">
        <svg viewBox="0 0 600 240" class="w-full h-full" preserveAspectRatio="none">
          <defs>
            <linearGradient id="visitors-grad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="oklch(68% 0.16 145)" stop-opacity="0.2"/>
              <stop offset="100%" stop-color="oklch(68% 0.16 145)" stop-opacity="0"/>
            </linearGradient>
          </defs>
          <line x1="0" y1="80" x2="600" y2="80" stroke="oklch(90% 0 0)" stroke-width="0.5"/>
          <line x1="0" y1="160" x2="600" y2="160" stroke="oklch(90% 0 0)" stroke-width="0.5"/>
          <path d="M0,200 L50,180 L100,160 L150,170 L200,120 L250,130 L300,80 L350,90 L400,60 L450,70 L500,40 L550,50 L600,30 L600,240 L0,240Z" fill="url(#visitors-grad)"/>
          <path d="M0,200 L50,180 L100,160 L150,170 L200,120 L250,130 L300,80 L350,90 L400,60 L450,70 L500,40 L550,50 L600,30" fill="none" stroke="oklch(68% 0.16 145)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <div class="absolute bottom-0 left-0 right-0 flex justify-between text-xs text-[var(--color-text-secondary)] pt-2">
          <span>Jan</span><span>Feb</span><span>Mär</span><span>Apr</span><span>Mai</span><span>Jun</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Top Pages -->
  <div class="glass-frosted rounded-2xl p-6 animate-fade-in-up stagger-7">
    <h2 class="text-lg font-semibold text-[var(--color-text)] mb-4">Top-Seiten</h2>
    <table class="w-full">
      <thead>
        <tr class="text-left text-xs font-medium text-[var(--color-text-secondary)] uppercase tracking-wider">
          <th class="pb-3 pr-4">Seite</th>
          <th class="pb-3 pr-4">Aufrufe</th>
          <th class="pb-3 pr-4">Einzigartig</th>
          <th class="pb-3 pr-4">Absprung</th>
          <th class="pb-3">Dauer</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-[var(--color-border)]">
        {[
          { page: '/dashboard', views: '12,430', unique: '8,210', bounce: '24%', duration: '5m 12s' },
          { page: '/products', views: '8,745', unique: '6,120', bounce: '31%', duration: '3m 45s' },
          { page: '/blog/astro-guide', views: '6,320', unique: '5,890', bounce: '18%', duration: '7m 30s' },
          { page: '/pricing', views: '4,218', unique: '3,650', bounce: '42%', duration: '2m 15s' },
          { page: '/about', views: '2,890', unique: '2,340', bounce: '55%', duration: '1m 48s' },
        ].map((row) => (
          <tr class="hover:bg-[var(--color-bg-secondary)]/50 transition-colors">
            <td class="py-3 pr-4 text-sm font-medium text-[var(--color-accent)]">{row.page}</td>
            <td class="py-3 pr-4 text-sm text-[var(--color-text)]">{row.views}</td>
            <td class="py-3 pr-4 text-sm text-[var(--color-text)]">{row.unique}</td>
            <td class="py-3 pr-4 text-sm text-[var(--color-text-secondary)]">{row.bounce}</td>
            <td class="py-3 text-sm text-[var(--color-text-secondary)]">{row.duration}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</DashboardLayout>

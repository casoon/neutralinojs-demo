---
import DashboardLayout from '../layouts/DashboardLayout.astro';

const teamMembers = [
  { initials: 'JS', name: 'Jan Seidel', role: 'Administrator', department: 'Engineering', email: 'jan@firma.de', status: 'online', projects: 6, tasks: 12, color: 'from-blue-500 to-cyan-400' },
  { initials: 'MK', name: 'Maria Krüger', role: 'UX Designerin', department: 'Design', email: 'maria@firma.de', status: 'online', projects: 4, tasks: 8, color: 'from-rose-400 to-pink-500' },
  { initials: 'TW', name: 'Thomas Weber', role: 'Senior Developer', department: 'Engineering', email: 'thomas@firma.de', status: 'online', projects: 5, tasks: 15, color: 'from-emerald-400 to-teal-500' },
  { initials: 'LB', name: 'Lisa Braun', role: 'Frontend Developerin', department: 'Engineering', email: 'lisa@firma.de', status: 'offline', projects: 3, tasks: 9, color: 'from-violet-400 to-purple-500' },
  { initials: 'PH', name: 'Peter Hoffmann', role: 'Backend Developer', department: 'Engineering', email: 'peter@firma.de', status: 'away', projects: 4, tasks: 11, color: 'from-amber-400 to-orange-500' },
  { initials: 'SK', name: 'Sarah Koch', role: 'Produkt Managerin', department: 'Produkt', email: 'sarah@firma.de', status: 'online', projects: 5, tasks: 7, color: 'from-cyan-400 to-blue-500' },
  { initials: 'AH', name: 'Alex Hartmann', role: 'DevOps Engineer', department: 'Engineering', email: 'alex@firma.de', status: 'offline', projects: 3, tasks: 6, color: 'from-indigo-400 to-violet-500' },
  { initials: 'NF', name: 'Nina Fischer', role: 'QA Testerin', department: 'Quality', email: 'nina@firma.de', status: 'online', projects: 4, tasks: 14, color: 'from-teal-400 to-emerald-500' },
];

const statusColors: Record<string, string> = {
  online: 'bg-[var(--color-success)]',
  offline: 'bg-slate-300',
  away: 'bg-[var(--color-warning)]',
};

const statusLabels: Record<string, string> = {
  online: 'Online',
  offline: 'Offline',
  away: 'Abwesend',
};
---

<DashboardLayout title="Team" subtitle="8 Mitglieder">
  <div class="flex items-center justify-between mb-6">
    <div class="flex gap-2">
      <button class="px-4 py-2 text-sm font-medium rounded-lg bg-[var(--color-accent)] text-white">Alle</button>
      <button class="px-4 py-2 text-sm font-medium rounded-lg text-[var(--color-text-secondary)] hover:bg-[var(--color-bg-secondary)] transition-colors">Engineering</button>
      <button class="px-4 py-2 text-sm font-medium rounded-lg text-[var(--color-text-secondary)] hover:bg-[var(--color-bg-secondary)] transition-colors">Design</button>
      <button class="px-4 py-2 text-sm font-medium rounded-lg text-[var(--color-text-secondary)] hover:bg-[var(--color-bg-secondary)] transition-colors">Produkt</button>
    </div>
    <button class="flex items-center gap-2 px-4 py-2 bg-[var(--color-accent)] text-white text-sm font-medium rounded-lg hover:bg-[var(--color-accent-hover)] transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
      Einladen
    </button>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    {teamMembers.map((member, i) => (
      <div class={`glass-frosted rounded-2xl p-6 text-center hover-lift animate-fade-in-up stagger-${i + 1}`}>
        <div class="relative inline-block mb-4">
          <div class={`w-16 h-16 rounded-full bg-gradient-to-br ${member.color} flex items-center justify-center text-white text-lg font-bold mx-auto`}>
            {member.initials}
          </div>
          <div class={`absolute bottom-0 right-0 w-4 h-4 ${statusColors[member.status]} rounded-full border-2 border-white`}></div>
        </div>
        <h3 class="font-semibold text-[var(--color-text)]">{member.name}</h3>
        <p class="text-sm text-[var(--color-accent)] mt-0.5">{member.role}</p>
        <p class="text-xs text-[var(--color-text-secondary)] mt-1">{member.department}</p>

        <div class="flex justify-center gap-6 mt-4 pt-4 border-t border-[var(--color-border)]">
          <div>
            <p class="text-lg font-bold text-[var(--color-text)]">{member.projects}</p>
            <p class="text-[11px] text-[var(--color-text-secondary)]">Projekte</p>
          </div>
          <div>
            <p class="text-lg font-bold text-[var(--color-text)]">{member.tasks}</p>
            <p class="text-[11px] text-[var(--color-text-secondary)]">Aufgaben</p>
          </div>
        </div>

        <div class="flex gap-2 mt-4">
          <button class="flex-1 px-3 py-1.5 text-xs font-medium rounded-lg bg-[var(--color-accent)]/10 text-[var(--color-accent)] hover:bg-[var(--color-accent)]/20 transition-colors">Profil</button>
          <button class="flex-1 px-3 py-1.5 text-xs font-medium rounded-lg bg-[var(--color-bg-secondary)] text-[var(--color-text-secondary)] hover:bg-[var(--color-border)] transition-colors">Nachricht</button>
        </div>
      </div>
    ))}
  </div>
</DashboardLayout>

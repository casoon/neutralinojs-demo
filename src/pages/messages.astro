---
import DashboardLayout from '../layouts/DashboardLayout.astro';

const conversations = [
  { initials: 'MK', name: 'Maria Krüger', message: 'Habe die Mockups fertig, kannst du dir das anschauen?', time: '09:42', unread: 2, online: true, color: 'from-rose-400 to-pink-500' },
  { initials: 'TW', name: 'Thomas Weber', message: 'PR ist gemergt, Tests laufen durch.', time: '09:15', unread: 0, online: true, color: 'from-emerald-400 to-teal-500' },
  { initials: 'LB', name: 'Lisa Braun', message: 'Können wir das Meeting auf 14 Uhr verschieben?', time: '08:55', unread: 1, online: false, color: 'from-violet-400 to-purple-500' },
  { initials: 'PH', name: 'Peter Hoffmann', message: 'Datenbankschema für die neue API ist fertig.', time: 'Gestern', unread: 0, online: false, color: 'from-amber-400 to-orange-500' },
  { initials: 'SK', name: 'Sarah Koch', message: 'Onboarding-Dokumente sind aktualisiert.', time: 'Gestern', unread: 0, online: true, color: 'from-cyan-400 to-blue-500' },
  { initials: 'AH', name: 'Alex Hartmann', message: 'Deployment Script braucht ein Update.', time: 'Mo.', unread: 0, online: false, color: 'from-indigo-400 to-violet-500' },
];

const selectedMessages = [
  { sender: 'Maria Krüger', time: '09:30', text: 'Hey Jan! Ich habe die Mockups für die Landing Page fertiggestellt.', own: false },
  { sender: 'Maria Krüger', time: '09:32', text: 'Sind im Figma-Projekt unter "Landing Page v3" zu finden.', own: false },
  { sender: 'Du', time: '09:35', text: 'Super, danke Maria! Schaue ich mir gleich an.', own: true },
  { sender: 'Maria Krüger', time: '09:38', text: 'Achte besonders auf die Hero-Section, da habe ich mit den Webspire Glass-Effekten experimentiert.', own: false },
  { sender: 'Du', time: '09:40', text: 'Oh nice, glass-frosted oder glass-subtle?', own: true },
  { sender: 'Maria Krüger', time: '09:42', text: 'Eine Kombination! Frosted für die Cards und Subtle für den Header. Sieht richtig clean aus.', own: false },
];
---

<DashboardLayout title="Nachrichten" subtitle="3 ungelesene Nachrichten">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 h-[calc(100vh-12rem)]">
    <!-- Conversation List -->
    <div class="glass-frosted rounded-2xl overflow-hidden animate-slide-in-left">
      <div class="p-4 border-b border-[var(--color-border)]">
        <div class="relative">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-[var(--color-text-secondary)]" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
          <input type="text" placeholder="Nachrichten durchsuchen..." class="w-full pl-9 pr-4 py-2 bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-lg text-sm" />
        </div>
      </div>
      <div class="overflow-y-auto" style="max-height: calc(100% - 65px);">
        {conversations.map((conv, i) => (
          <div class={`flex items-center gap-3 px-4 py-3 cursor-pointer transition-colors ${i === 0 ? 'bg-[var(--color-accent)]/5 border-l-2 border-[var(--color-accent)]' : 'hover:bg-[var(--color-bg-secondary)]/50 border-l-2 border-transparent'}`}>
            <div class="relative flex-shrink-0">
              <div class={`w-10 h-10 rounded-full bg-gradient-to-br ${conv.color} flex items-center justify-center text-white text-xs font-bold`}>
                {conv.initials}
              </div>
              {conv.online && (
                <div class="absolute -bottom-0.5 -right-0.5 w-3.5 h-3.5 bg-[var(--color-success)] rounded-full border-2 border-white"></div>
              )}
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex justify-between items-baseline">
                <p class="text-sm font-medium text-[var(--color-text)] truncate">{conv.name}</p>
                <span class="text-[11px] text-[var(--color-text-secondary)] flex-shrink-0 ml-2">{conv.time}</span>
              </div>
              <p class="text-xs text-[var(--color-text-secondary)] truncate mt-0.5">{conv.message}</p>
            </div>
            {conv.unread > 0 && (
              <span class="flex-shrink-0 w-5 h-5 bg-[var(--color-accent)] text-white text-[10px] font-bold rounded-full flex items-center justify-center">
                {conv.unread}
              </span>
            )}
          </div>
        ))}
      </div>
    </div>

    <!-- Chat Area -->
    <div class="lg:col-span-2 glass-frosted rounded-2xl overflow-hidden flex flex-col animate-fade-in-up">
      <!-- Chat Header -->
      <div class="flex items-center gap-3 px-6 py-4 border-b border-[var(--color-border)]">
        <div class="relative">
          <div class="w-10 h-10 rounded-full bg-gradient-to-br from-rose-400 to-pink-500 flex items-center justify-center text-white text-xs font-bold">MK</div>
          <div class="absolute -bottom-0.5 -right-0.5 w-3.5 h-3.5 bg-[var(--color-success)] rounded-full border-2 border-white"></div>
        </div>
        <div>
          <p class="font-medium text-sm text-[var(--color-text)]">Maria Krüger</p>
          <p class="text-xs text-[var(--color-success)]">Online</p>
        </div>
      </div>

      <!-- Messages -->
      <div class="flex-1 overflow-y-auto p-6 space-y-4">
        {selectedMessages.map((msg) => (
          <div class={`flex ${msg.own ? 'justify-end' : 'justify-start'}`}>
            <div class={`max-w-xs lg:max-w-md px-4 py-2.5 rounded-2xl ${
              msg.own
                ? 'bg-[var(--color-accent)] text-white rounded-br-md'
                : 'bg-[var(--color-bg-secondary)] text-[var(--color-text)] rounded-bl-md'
            }`}>
              <p class="text-sm">{msg.text}</p>
              <p class={`text-[10px] mt-1 ${msg.own ? 'text-white/60' : 'text-[var(--color-text-secondary)]'}`}>{msg.time}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Input -->
      <div class="px-6 py-4 border-t border-[var(--color-border)]">
        <div class="flex items-center gap-3">
          <input type="text" placeholder="Nachricht schreiben..." class="flex-1 px-4 py-2.5 bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]/30 focus:border-[var(--color-accent)]" />
          <button class="p-2.5 bg-[var(--color-accent)] text-white rounded-xl hover:bg-[var(--color-accent-hover)] transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>

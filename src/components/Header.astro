---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<header class="flex items-center justify-between h-16 px-8 border-b border-[var(--color-border)] bg-white/60 backdrop-blur-sm sticky top-0 z-20">
  <div>
    <h1 class="text-xl font-semibold text-[var(--color-text)]">{title}</h1>
    {subtitle && <p class="text-sm text-[var(--color-text-secondary)]">{subtitle}</p>}
  </div>

  <div class="flex items-center gap-4">
    <!-- Search -->
    <div class="relative">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-[var(--color-text-secondary)]" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
      </svg>
      <input
        type="text"
        placeholder="Suchen..."
        class="pl-9 pr-4 py-2 w-64 bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-lg text-sm text-[var(--color-text)] placeholder:text-[var(--color-text-secondary)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]/30 focus:border-[var(--color-accent)] transition-all"
      />
    </div>

    <!-- Notifications -->
    <button class="relative p-2 rounded-lg hover:bg-[var(--color-bg-secondary)] transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-text-secondary)]">
        <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/>
        <path d="M13.73 21a2 2 0 01-3.46 0"/>
      </svg>
      <span class="absolute top-1.5 right-1.5 w-2 h-2 bg-[var(--color-error)] rounded-full"></span>
    </button>
  </div>
</header>
